@model IEnumerable<StudentManagement.ViewModels.Course.CourseViewModel>

@{
    ViewData["Title"] = "Courses";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Courses</h2>

    <a asp-action="Create" class="btn btn-success">Add Course</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No courses have been added yet.
    </div>
}
else
{
    <table class="table table-hover table-striped table-bordered align-middle">

        <thead>
            <tr>
                <th>Course Code</th>
                <th>Course Name</th>
                <th>Credits</th>
                <th width="190"></th>
            </tr>
        </thead>

        <tbody>

            @foreach (var course in Model)
            {
                <tr>

                    <td>@course.CourseCode</td>
                    <td>@course.CourseName</td>
                    <td>@course.Credits</td>

                    <td>
                        <div class="btn-group">

                            <a asp-action="Details" asp-route-id="@course.Id" class="btn btn-info btn-sm">Details </a>

                            <a asp-action="Edit" asp-route-id="@course.Id" class="btn btn-warning btn-sm"> Edit</a>

                            <a asp-action="Delete" asp-route-id="@course.Id" class="btn btn-danger btn-sm"> Delete</a>

                        </div>
                    </td>

                </tr>
            }

        </tbody>

    </table>
}