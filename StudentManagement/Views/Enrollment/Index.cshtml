@using StudentManagement.Helpers
@model IEnumerable<StudentManagement.ViewModels.Enrollment.EnrollmentViewModel>

@{
    ViewData["Title"] = "Enrollments";
}

<div class="d-flex justify-content-between align-items-center mb-3">

    <h2 class="mb-0">Enrollments</h2>

    <a asp-action="Create" class="btn btn-success">Add Enrollment</a>

</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No enrollments found.
    </div>
}
else
{
    <table class="table table-hover table-striped table-bordered align-middle">

        <thead>

            <tr>
                <th>Student</th>
                <th>Course</th>
                <th>Enrolled</th>
                <th>Final Mark</th>
                <th>Status</th>
                <th width="190"></th>
            </tr>

        </thead>

        <tbody>

            @foreach (var enrollment in Model)
            {
                <tr>

                    <td>@enrollment.StudentName</td>

                    <td>@enrollment.CourseName</td>

                    <td>@enrollment.EnrolledDate.ToShortDateString()</td>

                    <td>@enrollment.FinalMark</td>

                    <td>@enrollment.Status</td>

                    <td>

                        <div class="btn-group">

                            <a asp-action="Details" asp-route-id="@enrollment.Id" class="btn btn-info btn-sm">Details</a>

                            <a asp-action="Edit" asp-route-id="@enrollment.Id" class="btn btn-warning btn-sm"> Edit</a>

                            @if (User.IsInRole(Roles.Admin))
                            {
                                <a asp-action="Delete" asp-route-id="@enrollment.Id" class="btn btn-danger btn-sm"> Delete</a>
                            }
                            
                        </div>

                    </td>

                </tr>
            }

        </tbody>

    </table>
}