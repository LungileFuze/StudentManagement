@model StudentManagement.ViewModels.Enrollment.EnrollmentDetailsViewModel

@{
    ViewData["Title"] = "Delete Enrollment";
}

<h2>Delete Enrollment</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this enrollment?
</div>

<dl class="row">

    <dt class="col-sm-3">Student</dt>
    <dd class="col-sm-9">@Model.StudentName</dd>

    <dt class="col-sm-3">Course</dt>
    <dd class="col-sm-9">@Model.CourseName</dd>

    <dt class="col-sm-3">Status</dt>
    <dd class="col-sm-9">@Model.Status</dd>

</dl>

<form asp-action="Delete">

    <input asp-for="Id" type="hidden" />

    <button type="submit" class="btn btn-danger"> Delete</button>

    <a asp-action="Index" class="btn btn-secondary"> Cancel </a>

</form>